<h1>Haven – Currently Signed In</h1>

<%= link_to "New Check-In", new_haven_check_in_path, class: "btn btn-success mb-3" %>

<% if @sign_ins.any? %>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Checked In</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @sign_ins.each do |sign_in| %>
        <tr>
          <td><%= sign_in.person.name %></td>
          <td><%= sign_in.checked_in_at&.strftime("%d %b %Y %H:%M") %></td>
          <td>
            <%= button_to "Sign Out", sign_out_haven_check_in_path(sign_in), method: :patch, class: "btn btn-warning btn-sm", data: { confirm: "Sign out #{sign_in.person.name}?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No guests are currently signed in to the Haven.</p>
<% end %>
