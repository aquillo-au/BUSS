<h1>Edit Sign-In</h1>
<%= form_with model: @sign_in, local: true do |f| %>
  <div class="mb-3">
    <%= f.label :arrived_at, "Arrived At" %>
    <%= f.datetime_select :arrived_at, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :left_at, "Left At" %>
    <%= f.datetime_select :left_at, class: "form-control", include_blank: true %>
  </div>
  <div class="mb-3 form-check">
    <%= f.check_box :activity, class: "form-check-input" %>
    <%= f.label :activity, "Activity?", class: "form-check-label" %>
  </div>
  <%= f.submit "Update", class: "btn btn-primary" %>
<% end %>
