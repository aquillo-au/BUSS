<%# Landing Page View %>

<%# ── Hero ─────────────────────────────────────────── %>
<section class="buss-hero">
  <img src="/icon.png" alt="" class="buss-hero-bg-logo" aria-hidden="true">
  <div class="container buss-hero-content text-center">
    <img src="/icon.png" alt="Bathurst Uniting Support Services logo" class="buss-logo mb-4">
    <h1 class="buss-hero-title">Creating Connection.<br>Affirming Dignity.<br>Supporting Growth.</h1>
    <p class="buss-hero-subtitle">
      Bathurst Uniting Support Services (BUSS) walks alongside people experiencing homelessness,
      poverty, and addiction &mdash; helping them reconnect with community and find a path forward.
    </p>
    <div class="buss-hero-ctas mt-4">
      <a href="<%= check_in_path %>" class="btn buss-btn-primary me-2"><span aria-hidden="true">&#10003;</span> Check In Now</a>
      <%= link_to "Haven Log In", new_haven_check_in_path, class: "btn buss-btn-secondary" %>
    </div>
  </div>
</section>

<%# ── Impact Stats ─────────────────────────────────────────── %>
<section class="buss-stats py-5">
  <div class="container">
    <div class="text-center mb-5">
      <img src="/icon.png" alt="" class="buss-stats-motif" aria-hidden="true">
      <h2 class="buss-section-title mt-3">Our Impact Last Year</h2>
    </div>
    <div class="row g-4 justify-content-center">

      <div class="col-6 col-md-4 col-lg-2">
        <div class="buss-stat-card">
          <div class="buss-stat-icon" aria-hidden="true">🍽️</div>
          <div class="buss-stat-number">3,000+</div>
          <div class="buss-stat-label">Meals Served</div>
        </div>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <div class="buss-stat-card">
          <div class="buss-stat-icon" aria-hidden="true">🚿</div>
          <div class="buss-stat-number">500+</div>
          <div class="buss-stat-label">Warm Showers</div>
        </div>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <div class="buss-stat-card">
          <div class="buss-stat-icon" aria-hidden="true">🎒</div>
          <div class="buss-stat-number">100+</div>
          <div class="buss-stat-label">Dignity Bags</div>
        </div>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <div class="buss-stat-card">
          <div class="buss-stat-icon" aria-hidden="true">🤝</div>
          <div class="buss-stat-number">75+</div>
          <div class="buss-stat-label">Volunteers</div>
        </div>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <div class="buss-stat-card">
          <div class="buss-stat-icon" aria-hidden="true">🔗</div>
          <div class="buss-stat-number">4,000+</div>
          <div class="buss-stat-label">Connections Made</div>
        </div>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <div class="buss-stat-card">
          <div class="buss-stat-icon" aria-hidden="true">⛺</div>
          <div class="buss-stat-number">60+</div>
          <div class="buss-stat-label">Crisis Tents Provided</div>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ── About ────────────────────────────────────────────────── %>
<section class="buss-about py-5">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-md-6 text-center">
        <div class="buss-about-logo-wrap">
          <img src="/icon.png" alt="BUSS bus logo" class="buss-about-icon">
        </div>
      </div>
      <div class="col-md-6">
        <h2 class="buss-section-title mb-4">What We Do</h2>
        <p class="buss-about-text">
          BUSS runs the weekend <strong>BUSS Café</strong> and a range of weekday programs for people
          who are homeless, poor, or socially isolated &mdash; as well as those living with or recovering from addiction.
        </p>
        <p class="buss-about-text">
          All our activities bring together participants and community volunteers, building real social connections
          and new skills. We believe <em>&ldquo;the opposite of addiction is not sobriety, it is connection.&rdquo;</em>
        </p>
        <p class="buss-about-text mb-0">
          Want to volunteer, donate, or find out more?
          Visit our <a href="https://www.facebook.com/BathurstBUSS" target="_blank" class="buss-link">Facebook page</a>
          or call us on <strong>0455&nbsp;328&nbsp;966</strong>.
        </p>
      </div>
    </div>
  </div>
</section>

<%# ── Facebook Feed ────────────────────────────────────────── %>
<section class="buss-feed py-5">
  <div class="container" style="max-width: 860px;">
    <h2 class="buss-section-title text-center mb-5">
      <span class="buss-fb-badge" aria-hidden="true">f</span> Latest from Facebook
    </h2>

    <% if @facebook_posts&.any? %>
      <% @facebook_posts.each do |post| %>
        <div class="buss-fb-card mb-4">
          <% if post.image_url.present? %>
            <img src="<%= post.image_url %>" alt="Post image" class="buss-fb-img">
          <% end %>
          <div class="buss-fb-body">
            <p class="buss-fb-text"><%= truncate(post.message, length: 300) %></p>
            <small class="buss-fb-time"><%= time_ago_in_words(post.published_at) %> ago</small>
            <% if post.post_url.present? %>
              <a href="<%= post.post_url %>" target="_blank" class="buss-fb-link">View on Facebook &rarr;</a>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="buss-feed-empty">No posts found yet. Check back soon for updates!</p>
    <% end %>
  </div>
</section>

<%# ── Admin Actions ────────────────────────────────────────── %>
<section class="buss-admin-bar py-3">
  <div class="container d-flex flex-wrap gap-2 justify-content-center align-items-center">
    <a href="<%= admin_path %>" class="btn buss-btn-admin"><span aria-hidden="true">&#9881;</span> Admin</a>
    <% if user_signed_in? %>
      <%= button_to "Log Out", logout_path, method: :delete, class: "btn buss-btn-logout" %>
    <% end %>
  </div>
</section>
